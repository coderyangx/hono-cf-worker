{
  "name": "hono-cf-worker",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "wrangler dev",
    "dev:hono": "node --import=tsx/esm --watch src/index.ts",
    "build": "vite build",
    "preview": "$npm_execpath run build && vite preview",
    "deploy": "$npm_execpath run build && wrangler deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "@ai-sdk/openai": "^2.0.10",
    "@hono/node-server": "^1.14.4",
    "ai": "^5.0.28",
    "hono": "^4.7.11",
    "zod": "^3.25.64"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.26.0",
    "@types/node": "^25.3.3",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-ssr-components": "^0.5.2",
    "wrangler": "^4.17.0"
  },
  "resolutions": {
    "ai": "5.x"
  }
}
